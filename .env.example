TWITTER_AUTH_MODE=oauth2

# OAuth 2.0 user context. Access token must include tweet.write.
TWITTER_CLIENT_ID=your_client_id
TWITTER_CLIENT_SECRET=your_client_secret
TWITTER_ACCESS_TOKEN=your_oauth2_access_token
TWITTER_REFRESH_TOKEN=your_oauth2_refresh_token

# OAuth 1.0a alternative. Use TWITTER_AUTH_MODE=oauth1 if you have these.
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_oauth1_access_token
# TWITTER_ACCESS_TOKEN_SECRET=your_oauth1_access_token_secret

# LLM provider:
# template = zero-cost, no model/API needed
# doubao = Volcengine Ark / Doubao Responses API
# ollama = free local model, requires Ollama running
# openai = paid API
LLM_PROVIDER=template
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Required only when LLM_PROVIDER=doubao.
# ARK_API_KEY=your_ark_api_key
# ARK_MODEL=doubao-seed-2-0-pro-260215
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# Required only when LLM_PROVIDER=openai.
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# Optional
# UTC+8 schedule tuned for US X traffic peaks:
# 00:30 = US midday/morning, 08:30 = US evening, 21:30 = US morning
POST_TIMES=00:30,08:30,21:30

# Content strategy. Keep these comma-separated and easy to edit.
TWEET_TOPICS=too many browser tabs,I'll read this later,research rabbit hole,ADHD browser chaos,designer inspiration hoarding,student research panic,AI workflow but messy browser,Chrome eating memory
TREND_KEYWORDS=AI workflow,deadline panic,study setup,designer problems,procrastination,Chrome tabs,research rabbit hole,too many tabs

# Optional official X trends. This may require a paid API tier.
ENABLE_X_TRENDS=false
TWITTER_BEARER_TOKEN=your_app_bearer_token
X_TRENDS_WOEID=1
